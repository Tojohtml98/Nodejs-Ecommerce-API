<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">E-commerce</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/home">Home</a>
                <a class="nav-link" href="/products">Productos</a>
                <a class="nav-link" href="/realtimeproducts">Tiempo Real</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <h1 class="mb-4">{{title}}</h1>
                <a href="/products" class="btn btn-secondary mb-3">← Continuar Comprando</a>
                
                {{#if cart}}
                    {{#if cart.products.length}}
                        <div class="card">
                            <div class="card-body">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Producto</th>
                                            <th>Precio</th>
                                            <th>Cantidad</th>
                                            <th>Total</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {{#each cart.products}}
                                        <tr>
                                            <td>
                                                <strong>{{this.productId.title}}</strong><br>
                                                <small class="text-muted">{{this.productId.description}}</small>
                                            </td>
                                            <td>${{this.productId.price}}</td>
                                            <td>{{this.quantity}}</td>
                                            <td class="subtotal">${{this.productId.price}}</td>
                                            <td>
                                                <button class="btn btn-sm btn-danger" onclick="removeProduct('{{../cart._id}}', '{{this.productId._id}}')">
                                                    Eliminar
                                                </button>
                                            </td>
                                        </tr>
                                        {{/each}}
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="3"><strong>Total</strong></td>
                                            <td><strong id="totalCart">$0</strong></td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                </table>
                                
                                <div class="mt-4">
                                    <button class="btn btn-danger" onclick="clearCart('{{cart._id}}')">
                                        Vaciar Carrito
                                    </button>
                                </div>
                            </div>
                        </div>
                    {{else}}
                        <div class="alert alert-info">
                            <h4>Carrito vacío</h4>
                            <p>No hay productos en tu carrito. <a href="/products">Ver productos</a></p>
                        </div>
                    {{/if}}
                {{else}}
                    <div class="alert alert-danger">
                        <h4>Carrito no encontrado</h4>
                        <p>El carrito que buscas no existe.</p>
                    </div>
                {{/if}}
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Calcular totales al cargar la página
        document.addEventListener('DOMContentLoaded', function() {
            calculateTotals();
        });
        
        function calculateTotals() {
            const rows = document.querySelectorAll('tbody tr');
            let total = 0;
            
            rows.forEach(row => {
                const priceCell = row.cells[1].textContent.replace('$', '');
                const quantityCell = row.cells[2].textContent;
                const subtotalCell = row.cells[3];
                
                const subtotal = parseFloat(priceCell) * parseInt(quantityCell);
                subtotalCell.textContent = '$' + subtotal.toFixed(2);
                total += subtotal;
            });
            
            document.getElementById('totalCart').textContent = '$' + total.toFixed(2);
        }
        
        async function removeProduct(cartId, productId) {
            if (!confirm('¿Estás seguro de que deseas eliminar este producto del carrito?')) {
                return;
            }
            
            try {
                const response = await fetch(`/api/carts/${cartId}/products/${productId}`, {
                    method: 'DELETE'
                });
                
                const data = await response.json();
                
                if (data.status === 'success') {
                    alert('Producto eliminado exitosamente');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (error) {
                alert('Error: ' + error.message);
            }
        }
        
        async function clearCart(cartId) {
            if (!confirm('¿Estás seguro de que deseas vaciar el carrito?')) {
                return;
            }
            
            try {
                const response = await fetch(`/api/carts/${cartId}`, {
                    method: 'DELETE'
                });
                
                const data = await response.json();
                
                if (data.status === 'success') {
                    alert('Carrito vaciado exitosamente');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (error) {
                alert('Error: ' + error.message);
            }
        }
    </script>
</body>
</html>

